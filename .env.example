# ============================================================================
# REQUIRED — EMBEDDINGS (always needed, regardless of LLM provider)
# ============================================================================
# The FAISS index was built with OpenAI text-embedding-3-small (1536 dims).
# Every query needs this key to convert text → vector. No alternative.
OPENAI_API_KEY=sk-...
# Get from: https://platform.openai.com/api-keys

# ============================================================================
# LLM PROVIDER SELECTION
# ============================================================================
# Choose one: gemini (default), openai, claude, ollama, openrouter
LLM_PROVIDER=gemini

# ============================================================================
# GEMINI CONFIGURATION (Google, free tier available)
# ============================================================================
GEMINI_API_KEY=your-gemini-api-key-here
# Get from: https://aistudio.google.com/

# ============================================================================
# OPENAI CONFIGURATION (GPT-4, requires paid API)
# ============================================================================
# OPENAI_API_KEY=sk-...
# Get from: https://platform.openai.com/api-keys

# ============================================================================
# ANTHROPIC CLAUDE CONFIGURATION
# ============================================================================
# ANTHROPIC_API_KEY=sk-ant-...
# Get from: https://console.anthropic.com/

# ============================================================================
# OLLAMA CONFIGURATION (Local, free, no internet needed)
# ============================================================================
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=mistral
# Download from: https://ollama.ai/

# ============================================================================
# OPENROUTER CONFIGURATION (100+ models via single API)
# ============================================================================
# OPENROUTER_API_KEY=sk-...
# OPENROUTER_MODEL=openai/gpt-4
# Available models: anthropic/claude-3-opus, mistralai/mixtral-8x7b, etc.
# Get from: https://openrouter.ai/
